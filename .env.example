# ─────────────────────────────────────────────────────────────
# NewsLens environment. Copy to `.env` and fill in as you wire up
# real services. Everything runs on mock data when DATA_MODE=mock,
# so none of the keys below are required for local development.
# ─────────────────────────────────────────────────────────────

# mock | live  — mock uses seed JSON + in-memory cache/search
DATA_MODE=mock

# ---- API ----
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=dev-only-change-me

# ---- Web ----
VITE_API_BASE_URL=http://localhost:4000

# ---- PostgreSQL (used when DATA_MODE=live) ----
DATABASE_URL=postgresql://newslens:newslens@localhost:5432/newslens

# ---- Redis (feed cache, trending, sessions) ----
REDIS_URL=redis://localhost:6379

# ---- Elasticsearch (full-text article search) ----
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=articles

# ---- OpenAI (summaries, bias detection, clustering assist) ----
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4o

# ---- Ingestion ----
NEWSAPI_KEY=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ---- Email (weekly digest) ----
SENDGRID_API_KEY=
DIGEST_FROM_EMAIL=digest@newslens.app
