{
  "name": "newslens",
  "version": "0.1.0",
  "private": true,
  "description": "NewsLens — a bias-aware, multi-source news aggregator with an AI personalization layer.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "start:api": "npm run start --workspace apps/api",
    "build:web": "npm run build --workspace apps/web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.17"
  }
}
